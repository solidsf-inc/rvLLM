# Required model and digest-verified kernel-artifact directories.
RVLLM_MODEL_DIR=/absolute/path/to/model
RVLLM_ARTIFACTS_DIR=/absolute/path/to/artifacts

# Public model label returned by /v1/models.
RVLLM_SERVED_MODEL_NAME=rvLLM

# Local container settings.
RVLLM_PORT=8080
RVLLM_IMAGE_TAG=<40-character-source-sha>
RUST_LOG=info

# Required trust pins for the selected kernel bundle and policy.
RVLLM_RELEASE_REVISION=<40-character-artifact-source-sha>
RVLLM_KERNEL_ARCH=sm_90
RVLLM_KERNEL_MANIFEST_SHA256=<64-character-manifest-digest>
RVLLM_POLICY_SHA256=<64-character-policy-digest>

# Required provenance fields for benchmark receipts.
RVLLM_SOURCE_SHA=<40-character-source-sha>
RVLLM_MODEL_ID=publisher/model@revision
RVLLM_MODEL_SHA256=<64-character-model-artifact-digest>
RVLLM_HARDWARE=<exact-accelerator-and-memory-configuration>
RVLLM_DRIVER=<exact-driver-version>
RVLLM_TOOLCHAIN=<exact-compiler-toolchain>

# Optional local bearer token. Supply the real value outside version control.
# RVLLM_API_KEY=<secret>

# Optional server controls implemented by v3/rvllm-server.
# RVLLM_BACKEND=cuda
# RVLLM_MAX_INFLIGHT_REQUESTS=4
# RVLLM_SYSTEM_PROMPT_FILE=/absolute/path/to/system-prompt.txt
# RVLLM_VISION_WEIGHTS_DIR=/absolute/path/to/native-model-vision-weights
